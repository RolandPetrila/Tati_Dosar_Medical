# .gitignore — Dosar medical Petrilă Viorel-Mihai
#
# NOTA: conform STRUCTURA_PROIECT.md § "Git remote", .gitignore nu e
# necesar funcțional (toate fișierele de proiect trebuie incluse).
# Ignorăm doar artefactele OS / IDE care nu aparțin dosarului.

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.Trash-*

# Editor temp
*.swp
*.swo
*~.tmp

# Microsoft Office lock files (apar cand un DOCX/XLSX e deschis in Word/Excel)
~$*.docx
~$*.xlsx
~$*.pptx
~$*.doc
~$*.xls

# IDE local
.vscode/
.idea/

# Claude Code output folders (rapoarte temporare skill-uri ca /review --full)
.claude-outputs/

# Claude Code config local (per-user, nu per-proiect)
.claude/settings.local.json

# Secrete (safety net — niciun fișier .env planificat, dar previne accidente)
.env
.env.*
*.secret
credentials.json

# Ciorne locale nedecise (rămân pe disc pentru inspecție, nu se versionează)
info_tati.txt
tati.png
